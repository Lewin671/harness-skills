#!/usr/bin/env bash
set -euo pipefail

src_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
dest_root="${1:-/Users/qingyingliu/.agents/skills}"

mkdir -p "${dest_root}"

linked=0
skipped=0

for skill_dir in "${src_root}"/*; do
  [ -d "${skill_dir}" ] || continue
  [ -f "${skill_dir}/SKILL.md" ] || continue

  skill_name="$(basename "${skill_dir}")"
  dest_path="${dest_root}/${skill_name}"

  if [ -L "${dest_path}" ]; then
    target="$(readlink "${dest_path}")"
    if [ "${target}" = "${skill_dir}" ]; then
      echo "skip  ${skill_name} (already linked)"
      skipped=$((skipped + 1))
      continue
    fi
    rm "${dest_path}"
  elif [ -e "${dest_path}" ]; then
    echo "skip  ${skill_name} (destination exists and is not a symlink: ${dest_path})" >&2
    skipped=$((skipped + 1))
    continue
  fi

  ln -s "${skill_dir}" "${dest_path}"
  echo "link  ${skill_name} -> ${dest_path}"
  linked=$((linked + 1))
done

echo "done  linked=${linked} skipped=${skipped} dest=${dest_root}"
