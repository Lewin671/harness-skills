#!/usr/bin/env bash
set -euo pipefail

src_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

default_dest_roots=(
  "${HOME}/.agents/skills"
  "${HOME}/.claude/skills"
  "${HOME}/.codex/skills"
  "${HOME}/.kiro/skills"
)

if [ "$#" -gt 0 ]; then
  dest_roots=("$@")
else
  dest_roots=("${default_dest_roots[@]}")
fi

is_repo_managed_link() {
  local path="$1"
  local target

  target="$(normalized_link_target "${path}")" || return 1
  path_is_under "${target}" "${src_root}"
}

casefold_path() {
  printf '%s\n' "$1" | tr '[:upper:]' '[:lower:]'
}

paths_equal() {
  [ "$(casefold_path "$1")" = "$(casefold_path "$2")" ]
}

path_is_under() {
  local path base

  path="$(casefold_path "$1")"
  base="$(casefold_path "$2")"
  [[ "${path}" = "${base}"/* ]]
}

normalized_path() {
  local path="$1"
  local parent

  parent="$(cd "$(dirname "${path}")" 2>/dev/null && pwd -P)" || return 1
  printf '%s/%s\n' "${parent}" "$(basename "${path}")"
}

normalized_link_target() {
  local path="$1"
  local target

  target="$(readlink "${path}")"
  if [[ "${target}" != /* ]]; then
    target="$(cd "$(dirname "${path}")" && pwd -P)/${target}"
  fi

  normalized_path "${target}"
}

cleanup_invalid_links() {
  local dest_root="$1"
  local dest_path skill_name expected_target target

  for dest_path in "${dest_root}"/*; do
    [ -L "${dest_path}" ] || continue
    skill_name="$(basename "${dest_path}")"
    expected_target="${src_root}/${skill_name}"
    target="$(normalized_link_target "${dest_path}" 2>/dev/null || true)"

    if [ ! -e "${dest_path}" ]; then
      if is_repo_managed_link "${dest_path}"; then
        rm "${dest_path}"
        echo "clean ${skill_name} (broken link)"
        removed=$((removed + 1))
      fi
      continue
    fi

    if ! is_repo_managed_link "${dest_path}"; then
      continue
    fi

    if [ ! -f "${expected_target}/SKILL.md" ] || ! paths_equal "${target}" "${expected_target}"; then
      rm "${dest_path}"
      echo "clean ${skill_name} (stale link)"
      removed=$((removed + 1))
    fi
  done
}

sync_dest_root() {
  local dest_root="$1"
  local linked=0
  local skipped=0
  local removed=0
  local skill_dir skill_name dest_path target

  mkdir -p "${dest_root}"

  cleanup_invalid_links "${dest_root}"

  for skill_dir in "${src_root}"/*; do
    [ -d "${skill_dir}" ] || continue
    [ -f "${skill_dir}/SKILL.md" ] || continue

    skill_name="$(basename "${skill_dir}")"
    dest_path="${dest_root}/${skill_name}"

    if [ -L "${dest_path}" ]; then
      target="$(normalized_link_target "${dest_path}" 2>/dev/null || true)"
      if [ -n "${target}" ] && paths_equal "${target}" "${skill_dir}"; then
        echo "skip  ${skill_name} (already linked)"
        skipped=$((skipped + 1))
        continue
      fi
      rm "${dest_path}"
    elif [ -e "${dest_path}" ]; then
      echo "skip  ${skill_name} (destination exists and is not a symlink: ${dest_path})" >&2
      skipped=$((skipped + 1))
      continue
    fi

    ln -s "${skill_dir}" "${dest_path}"
    echo "link  ${skill_name} -> ${dest_path}"
    linked=$((linked + 1))
  done

  echo "done  linked=${linked} skipped=${skipped} removed=${removed} dest=${dest_root}"
}

for dest_root in "${dest_roots[@]}"; do
  sync_dest_root "${dest_root}"
done
