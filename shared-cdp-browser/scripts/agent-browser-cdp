#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cdp_url="$("${script_dir}/ensure-cdp-browser")"
host="${SHARED_CDP_BROWSER_HOST:-127.0.0.1}"
port="${SHARED_CDP_BROWSER_PORT:-9222}"
lock_key="${host//[^[:alnum:]]/_}-${port}"
session_name="${SHARED_CDP_BROWSER_SESSION:-}"
session_marker="shared-cdp:${session_name}"
session_marker_b64="$(printf '%s' "${session_marker}" | base64 | tr -d '\r\n')"
command_lock="${SHARED_CDP_BROWSER_COMMAND_LOCK:-/tmp/shared-cdp-browser-command-${lock_key}.lock}"

run_agent_browser() {
  local cmd=()
  if command -v agent-browser >/dev/null 2>&1; then
    cmd=(agent-browser)
  else
    cmd=(npx -y agent-browser)
  fi

  cmd+=(--cdp "${cdp_url}")
  if [ -n "${session_name}" ]; then
    cmd+=(--session "${session_name}")
  fi

  "${cmd[@]}" "$@"
}

list_tab_indexes() {
  run_agent_browser tab list 2>/dev/null | sed -n 's/.*\[\([0-9][0-9]*\)\].*/\1/p'
}

find_session_tab() {
  local idx name
  while IFS= read -r idx; do
    [ -n "${idx}" ] || continue
    run_agent_browser tab "${idx}" >/dev/null 2>&1 || continue
    name="$(run_agent_browser eval 'window.name' 2>/dev/null | tr -d '"' || true)"
    if [ "${name}" = "${session_marker_b64}" ]; then
      printf '%s\n' "${idx}"
      return 0
    fi
  done < <(list_tab_indexes)

  return 1
}

ensure_session_tab() {
  [ -n "${session_name}" ] || return 0

  local idx
  if idx="$(find_session_tab)"; then
    run_agent_browser tab "${idx}" >/dev/null
    return 0
  fi

  run_agent_browser tab new >/dev/null
  run_agent_browser eval "window.name = '${session_marker_b64}'; window.name" >/dev/null
}

with_command_lock() {
  if command -v flock >/dev/null 2>&1; then
    exec 9>"${command_lock}"
    flock 9
    "$@"
    return
  fi

  local lock_dir="${command_lock}.d"
  local lock_pid_file="${lock_dir}/pid"
  local lock_pid

  while ! mkdir "${lock_dir}" 2>/dev/null; do
    if [ -f "${lock_pid_file}" ]; then
      lock_pid="$(cat "${lock_pid_file}" 2>/dev/null || true)"
      if [ -n "${lock_pid}" ] && ! kill -0 "${lock_pid}" 2>/dev/null; then
        rm -f "${lock_pid_file}"
        rmdir "${lock_dir}" 2>/dev/null || true
        continue
      fi
    fi
    sleep 0.1
  done
  printf '%s\n' "$$" >"${lock_pid_file}"
  trap 'rm -f "${lock_pid_file}"; rmdir "${lock_dir}" 2>/dev/null || true' RETURN
  "$@"
}

main() {
  if [ -n "${session_name}" ]; then
    case "${exec_cmd[0]}" in
      session|connect)
        ;;
      tab)
        if [ "${exec_cmd[1]:-}" = "new" ]; then
          local tmp_output
          tmp_output="$(mktemp)"
          trap 'rm -f "${tmp_output}"' RETURN
          run_agent_browser "${exec_cmd[@]}" >"${tmp_output}"
          run_agent_browser eval "window.name = '${session_marker_b64}'; window.name" >/dev/null
          cat "${tmp_output}"
          return 0
        fi
        ensure_session_tab
        ;;
      *)
        ensure_session_tab
        ;;
    esac
  fi

  run_agent_browser "${exec_cmd[@]}"
}

exec_cmd=("$@")
if [ "${#exec_cmd[@]}" -eq 0 ]; then
  echo "Usage: agent-browser-cdp <agent-browser args...>" >&2
  exit 1
fi

with_command_lock main
