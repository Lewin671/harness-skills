#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cdp_url="$("${script_dir}/ensure-cdp-browser")"
host="${SHARED_CDP_BROWSER_HOST:-127.0.0.1}"
port="${SHARED_CDP_BROWSER_PORT:-9222}"
lock_key="${host//[^[:alnum:]]/_}-${port}"
session_name="${SHARED_CDP_BROWSER_SESSION:-}"
session_name_b64="$(printf '%s' "${session_name}" | base64 | tr -d '\r\n')"
session_key="$(printf '%s' "${session_name_b64}" | tr '/+=' '_-.')"
command_lock="${SHARED_CDP_BROWSER_COMMAND_LOCK:-/tmp/shared-cdp-browser-command-${lock_key}.lock}"
session_ttl_default="${SHARED_CDP_BROWSER_SESSION_TTL:-1800}"
session_auto_renew="${SHARED_CDP_BROWSER_AUTO_RENEW:-1}"
quiet_mode="${SHARED_CDP_BROWSER_QUIET:-0}"
lock_stale_after="${SHARED_CDP_BROWSER_LOCK_STALE_AFTER:-5}"
state_dir="${SHARED_CDP_BROWSER_STATE_DIR:-${TMPDIR:-/tmp}/shared-cdp-browser-state-${lock_key}}"
lease_dir="${state_dir}/leases"

base64_decode() {
  if printf '%s' "${1}" | base64 --decode >/dev/null 2>&1; then
    printf '%s' "${1}" | base64 --decode
    return 0
  fi

  printf '%s' "${1}" | base64 -D
}

now_epoch() {
  date +%s
}

process_start_time() {
  local pid="${1}"
  ps -o lstart= -p "${pid}" 2>/dev/null | sed 's/^[[:space:]]*//'
}

require_positive_integer() {
  local value="${1}"
  local label="${2}"

  if ! [[ "${value}" =~ ^[0-9]+$ ]] || [ "${value}" -le 0 ]; then
    echo "${label} must be a positive integer." >&2
    exit 1
  fi
}

lock_age_seconds() {
  local path="${1}"
  local modified_at

  modified_at="$(date -r "${path}" +%s 2>/dev/null)" || return 1
  echo "$(( $(now_epoch) - modified_at ))"
}

require_session_name() {
  if [ -z "${session_name}" ]; then
    echo "SHARED_CDP_BROWSER_SESSION must be set for session commands." >&2
    exit 1
  fi
}

quiet_mode_auto_bind_error() {
  if [ -n "${session_name}" ]; then
    echo "Quiet mode will not auto-recover session ${session_name}. Run 'session open' explicitly if you want to rebind it." >&2
  else
    echo "Quiet mode will not auto-switch or create a session tab." >&2
  fi
}

parse_ttl_flag() {
  local ttl="${session_ttl_default}"
  local arg

  while [ "${#session_args[@]}" -gt 0 ]; do
    arg="${session_args[0]}"
    case "${arg}" in
      --ttl)
        if [ "${#session_args[@]}" -lt 2 ]; then
          echo "--ttl requires a value." >&2
          exit 1
        fi
        ttl="${session_args[1]}"
        session_args=("${session_args[@]:2}")
        ;;
      --ttl=*)
        ttl="${arg#--ttl=}"
        session_args=("${session_args[@]:1}")
        ;;
      *)
        break
        ;;
    esac
  done

  require_positive_integer "${ttl}" "TTL"
  parsed_ttl="${ttl}"
}

run_agent_browser() {
  local cmd=()
  if command -v agent-browser >/dev/null 2>&1; then
    cmd=(agent-browser)
  else
    cmd=(npx -y agent-browser)
  fi

  cmd+=(--cdp "${cdp_url}")
  if [ -n "${session_name}" ]; then
    cmd+=(--session "${session_name}")
  fi

  "${cmd[@]}" "$@"
}

agent_browser_runtime_dir() {
  if [ -n "${AGENT_BROWSER_SOCKET_DIR:-}" ]; then
    printf '%s\n' "${AGENT_BROWSER_SOCKET_DIR}"
    return 0
  fi

  if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
    printf '%s/agent-browser\n' "${XDG_RUNTIME_DIR}"
    return 0
  fi

  if [ -n "${HOME:-}" ]; then
    printf '%s/.agent-browser\n' "${HOME}"
    return 0
  fi

  printf '%s/agent-browser\n' "${TMPDIR:-/tmp}"
}

agent_browser_pid_file() {
  printf '%s/%s.pid\n' "$(agent_browser_runtime_dir)" "${session_name}"
}

current_daemon_identity() {
  local pid_file pid started

  [ -n "${session_name}" ] || return 1
  pid_file="$(agent_browser_pid_file)"
  [ -f "${pid_file}" ] || return 1

  pid="$(cat "${pid_file}" 2>/dev/null || true)"
  [ -n "${pid}" ] || return 1
  kill -0 "${pid}" 2>/dev/null || return 1

  started="$(process_start_time "${pid}")"
  [ -n "${started}" ] || return 1

  current_daemon_pid="${pid}"
  current_daemon_started="${started}"
}

lease_file_path() {
  printf '%s/%s.lease\n' "${lease_dir}" "${session_key}"
}

ensure_state_dirs() {
  mkdir -p "${lease_dir}"
}

lease_remove() {
  local lease_file
  lease_file="$(lease_file_path)"
  rm -f "${lease_file}"
}

read_lease_file() {
  local lease_file="${1}"
  [ -f "${lease_file}" ] || return 1

  lease_session_name_b64=""
  lease_target_id=""
  lease_expires_at=""
  lease_ttl=""
  lease_daemon_pid=""
  lease_daemon_started=""

  while IFS='=' read -r key value; do
    case "${key}" in
      session_name_b64) lease_session_name_b64="${value}" ;;
      target_id) lease_target_id="${value}" ;;
      expires_at) lease_expires_at="${value}" ;;
      ttl) lease_ttl="${value}" ;;
      daemon_pid) lease_daemon_pid="${value}" ;;
      daemon_started) lease_daemon_started="${value}" ;;
    esac
  done <"${lease_file}"

  [ -n "${lease_target_id}" ] || return 1
  [[ "${lease_expires_at}" =~ ^[0-9]+$ ]] || return 1
  [[ "${lease_ttl}" =~ ^[0-9]+$ ]] || return 1
}

load_session_lease() {
  local lease_file
  lease_file="$(lease_file_path)"
  read_lease_file "${lease_file}"
}

json_filter() {
  local script="${1}"

  if command -v python3 >/dev/null 2>&1; then
    python3 -c "${script}"
    return
  fi

  python -c "${script}"
}

list_targets_tsv() {
  local targets_json

  targets_json="$(curl --silent --show-error --fail "${cdp_url}/json/list")"
  printf '%s' "${targets_json}" | json_filter '
import json
import sys

data = json.load(sys.stdin)
for item in data:
    if item.get("type") != "page":
        continue
    target_id = item.get("id", "")
    if not target_id:
        continue
    title = item.get("title", "").replace("\t", " ").replace("\n", " ")
    url = item.get("url", "").replace("\t", " ").replace("\n", " ")
    print(f"{target_id}\t{title}\t{url}")
'
}

target_exists() {
  local target_id="${1}"
  list_targets_tsv | awk -F '\t' -v target_id="${target_id}" '$1 == target_id { found = 1 } END { exit(found ? 0 : 1) }'
}

current_tab_index() {
  run_agent_browser --json tab list 2>/dev/null | json_filter '
import json
import sys

payload = json.load(sys.stdin)
active = payload.get("data", {}).get("active")
if active is None:
    raise SystemExit(1)
print(active)
'
}

target_id_for_index() {
  local wanted_index="${1}"
  list_targets_tsv | awk -F '\t' -v wanted_index="${wanted_index}" 'NR - 1 == wanted_index { print $1; found = 1; exit } END { exit(found ? 0 : 1) }'
}

current_target_id() {
  local idx
  idx="$(current_tab_index)"
  target_id_for_index "${idx}"
}

activate_target() {
  local target_id="${1}"

  if curl --silent --show-error --fail "${cdp_url}/json/activate/${target_id}" >/dev/null 2>&1; then
    return 0
  fi

  local idx
  idx="$(target_id_for_index_lookup "${target_id}")" || return 1
  run_agent_browser tab "${idx}" >/dev/null
}

close_target() {
  local target_id="${1}"

  if curl --silent --show-error --fail "${cdp_url}/json/close/${target_id}" >/dev/null 2>&1; then
    return 0
  fi

  local idx
  idx="$(target_id_for_index_lookup "${target_id}")" || return 1
  run_agent_browser tab close "${idx}" >/dev/null
}

target_id_for_index_lookup() {
  local target_id="${1}"
  list_targets_tsv | awk -F '\t' -v target_id="${target_id}" '{
    if ($1 == target_id) {
      print NR - 1
      found = 1
      exit
    }
  } END { exit(found ? 0 : 1) }'
}

capture_target_ids() {
  list_targets_tsv | awk -F '\t' '{ print $1 }'
}

find_new_target_id() {
  local before_file="${1}"
  local after_file="${2}"

  awk 'NR==FNR { seen[$0]=1; next } !seen[$0] { print; exit }' "${before_file}" "${after_file}"
}

mark_current_tab() {
  local ttl="${1:-${session_ttl_default}}"
  local expires_at target_id

  [ -n "${session_name}" ] || return 0
  require_positive_integer "${ttl}" "TTL"
  target_id="$(current_target_id)"
  expires_at="$(( $(now_epoch) + ttl ))"
  lease_write "${target_id}" "${expires_at}" "${ttl}"
}

write_existing_lease() {
  [ -n "${lease_target_id:-}" ] || return 1
  lease_write "${lease_target_id}" "${lease_expires_at}" "${lease_ttl}"
}

write_existing_lease_preserving_binding() {
  local lease_file

  [ -n "${lease_target_id:-}" ] || return 1
  ensure_state_dirs
  lease_file="$(lease_file_path)"
  cat >"${lease_file}" <<EOF
session_name_b64=${lease_session_name_b64}
target_id=${lease_target_id}
expires_at=${lease_expires_at}
ttl=${lease_ttl}
daemon_pid=${lease_daemon_pid}
daemon_started=${lease_daemon_started}
EOF
}

lease_write() {
  local target_id="${1}"
  local expires_at="${2}"
  local ttl="${3}"
  local lease_file
  local daemon_pid_to_write daemon_started_to_write

  ensure_state_dirs
  lease_file="$(lease_file_path)"
  if current_daemon_identity 2>/dev/null; then
    daemon_pid_to_write="${current_daemon_pid}"
    daemon_started_to_write="${current_daemon_started}"
  else
    daemon_pid_to_write=""
    daemon_started_to_write=""
  fi
  cat >"${lease_file}" <<EOF
session_name_b64=${session_name_b64}
target_id=${target_id}
expires_at=${expires_at}
ttl=${ttl}
daemon_pid=${daemon_pid_to_write}
daemon_started=${daemon_started_to_write}
EOF
}

daemon_binding_is_current() {
  [ -n "${lease_daemon_pid:-}" ] || return 1
  [ -n "${lease_daemon_started:-}" ] || return 1
  current_daemon_identity || return 1
  [ "${lease_daemon_pid}" = "${current_daemon_pid}" ] && [ "${lease_daemon_started}" = "${current_daemon_started}" ]
}

session_target_id() {
  require_session_name
  load_session_lease
  printf '%s\n' "${lease_target_id}"
}

ensure_session_tab() {
  [ -n "${session_name}" ] || return 0

  if load_session_lease 2>/dev/null && target_exists "${lease_target_id}"; then
    if daemon_binding_is_current; then
      return 0
    fi
    if [ "${quiet_mode}" = "1" ]; then
      quiet_mode_auto_bind_error
      return 1
    fi
    activate_target "${lease_target_id}" >/dev/null
    write_existing_lease
    return 0
  fi

  if [ "${quiet_mode}" = "1" ]; then
    quiet_mode_auto_bind_error
    return 1
  fi

  lease_remove
  run_agent_browser tab new >/dev/null
  mark_current_tab "${session_ttl_default}"
}

cleanup_stale_session_tabs() {
  local now lease_file

  cleanup_removed_count=0
  ensure_state_dirs
  now="$(now_epoch)"

  while IFS= read -r lease_file; do
    [ -n "${lease_file}" ] || continue

    if ! read_lease_file "${lease_file}"; then
      rm -f "${lease_file}"
      continue
    fi

    if ! target_exists "${lease_target_id}"; then
      rm -f "${lease_file}"
      continue
    fi

    if [ "${lease_expires_at}" -gt "${now}" ]; then
      continue
    fi

    close_target "${lease_target_id}" >/dev/null 2>&1 || true
    rm -f "${lease_file}"
    cleanup_removed_count=$((cleanup_removed_count + 1))
  done < <(find "${lease_dir}" -type f -name '*.lease' -print 2>/dev/null | sort)
}

session_status() {
  local now remaining decoded_name

  require_session_name
  cleanup_stale_session_tabs

  if ! load_session_lease 2>/dev/null; then
    echo "session=${session_name}"
    echo "status=missing"
    return 1
  fi

  if ! target_exists "${lease_target_id}"; then
    lease_remove
    echo "session=${session_name}"
    echo "status=missing"
    return 1
  fi

  decoded_name="$(base64_decode "${lease_session_name_b64}")"
  now="$(now_epoch)"
  remaining="$(( lease_expires_at - now ))"
  if [ "${remaining}" -lt 0 ]; then
    remaining=0
  fi

  echo "session=${decoded_name}"
  echo "status=active"
  echo "target_id=${lease_target_id}"
  echo "ttl_seconds=${lease_ttl}"
  echo "expires_at=${lease_expires_at}"
  echo "remaining_seconds=${remaining}"
}

session_open() {
  local before_ids after_ids target_id

  require_session_name
  parse_ttl_flag
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session open does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs

  if load_session_lease 2>/dev/null && target_exists "${lease_target_id}"; then
    if ! daemon_binding_is_current; then
      activate_target "${lease_target_id}" >/dev/null
    fi
  else
    lease_remove
    before_ids="$(mktemp)"
    after_ids="$(mktemp)"
    capture_target_ids >"${before_ids}"
    run_agent_browser tab new >/dev/null
    capture_target_ids >"${after_ids}"
    target_id="$(find_new_target_id "${before_ids}" "${after_ids}" || true)"
    rm -f "${before_ids}" "${after_ids}"
    if [ -z "${target_id}" ]; then
      target_id="$(current_target_id)"
    fi
    lease_write "${target_id}" "$(( $(now_epoch) + parsed_ttl ))" "${parsed_ttl}"
    session_status
    return 0
  fi

  mark_current_tab "${parsed_ttl}"
  session_status
}

session_renew() {
  require_session_name
  parse_ttl_flag
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session renew does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs

  if ! load_session_lease 2>/dev/null || ! target_exists "${lease_target_id}"; then
    lease_remove
    echo "Session not found: ${session_name}" >&2
    exit 1
  fi

  lease_expires_at="$(( $(now_epoch) + parsed_ttl ))"
  lease_ttl="${parsed_ttl}"
  write_existing_lease_preserving_binding
  session_status
}

session_close() {
  require_session_name
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session close does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs

  if ! load_session_lease 2>/dev/null || ! target_exists "${lease_target_id}"; then
    lease_remove
    echo "session=${session_name}"
    echo "status=missing"
    return 1
  fi

  close_target "${lease_target_id}" >/dev/null
  lease_remove
  echo "session=${session_name}"
  echo "status=closed"
}

session_cleanup() {
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session cleanup does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs
  echo "removed=${cleanup_removed_count}"
}

handle_session_command() {
  local subcommand="${exec_cmd[1]:-}"

  session_args=("${exec_cmd[@]:2}")
  case "${subcommand}" in
    open)
      session_open
      ;;
    renew)
      session_renew
      ;;
    ttl)
      if [ "${#session_args[@]}" -gt 0 ]; then
        echo "session ttl does not accept extra arguments." >&2
        exit 1
      fi
      session_status
      ;;
    close)
      session_close
      ;;
    cleanup)
      session_cleanup
      ;;
    ""|list)
      run_agent_browser "${exec_cmd[@]}"
      ;;
    *)
      echo "Unknown session command: ${subcommand}" >&2
      exit 1
      ;;
  esac
}

write_lock_owner() {
  {
    printf 'pid=%s\n' "$$"
    printf 'started=%s\n' "$(process_start_time "$$")"
  } >"${lock_pid_file}"
}

read_lock_owner() {
  lock_owner_pid=""
  lock_owner_started=""
  [ -f "${lock_pid_file}" ] || return 1

  while IFS='=' read -r key value; do
    case "${key}" in
      pid) lock_owner_pid="${value}" ;;
      started) lock_owner_started="${value}" ;;
    esac
  done <"${lock_pid_file}"

  [ -n "${lock_owner_pid}" ] || return 1
}

lock_is_stale() {
  local current_start lock_age

  if ! read_lock_owner; then
    lock_age="$(lock_age_seconds "${lock_dir}" 2>/dev/null || true)"
    [ -n "${lock_age}" ] && [ "${lock_age}" -ge "${lock_stale_after}" ]
    return
  fi

  if ! kill -0 "${lock_owner_pid}" 2>/dev/null; then
    return 0
  fi

  current_start="$(process_start_time "${lock_owner_pid}")"
  [ -n "${current_start}" ] || return 0
  [ "${current_start}" != "${lock_owner_started}" ]
}

with_command_lock() {
  if [ "${SHARED_CDP_BROWSER_DISABLE_FLOCK:-0}" != "1" ] && command -v flock >/dev/null 2>&1; then
    exec 9>"${command_lock}"
    flock 9
    "$@"
    return
  fi

  local lock_dir="${command_lock}.d"
  lock_pid_file="${lock_dir}/pid"
  local status

  while ! mkdir "${lock_dir}" 2>/dev/null; do
    if lock_is_stale; then
      rm -f "${lock_pid_file}"
      rmdir "${lock_dir}" 2>/dev/null || true
      continue
    fi
    sleep 0.1
  done

  write_lock_owner
  if "$@"; then
    status=0
  else
    status=$?
  fi
  rm -f "${lock_pid_file}"
  rmdir "${lock_dir}" 2>/dev/null || true
  return "${status}"
}

main() {
  local status

  if [ "${exec_cmd[0]}" = "session" ] && [ "${#exec_cmd[@]}" -ge 2 ]; then
    handle_session_command
    return 0
  fi

  cleanup_stale_session_tabs

  if [ -n "${session_name}" ]; then
    case "${exec_cmd[0]}" in
      session|connect)
        ;;
      tab)
        if [ "${exec_cmd[1]:-}" = "new" ]; then
          local tmp_output before_ids after_ids target_id status
          tmp_output="$(mktemp)"
          before_ids="$(mktemp)"
          after_ids="$(mktemp)"
          capture_target_ids >"${before_ids}"
          if run_agent_browser "${exec_cmd[@]}" >"${tmp_output}"; then
            capture_target_ids >"${after_ids}"
            if [ "${session_auto_renew}" != "0" ]; then
              target_id="$(find_new_target_id "${before_ids}" "${after_ids}" || true)"
              if [ -z "${target_id}" ]; then
                target_id="$(current_target_id)"
              fi
              lease_write "${target_id}" "$(( $(now_epoch) + session_ttl_default ))" "${session_ttl_default}"
            fi
            cat "${tmp_output}"
            rm -f "${tmp_output}" "${before_ids}" "${after_ids}"
            return 0
          else
            status=$?
            rm -f "${tmp_output}" "${before_ids}" "${after_ids}"
            return "${status}"
          fi
        fi
        if [[ "${exec_cmd[1]:-}" =~ ^[0-9]+$ ]]; then
          run_agent_browser "${exec_cmd[@]}"
          if [ "${session_auto_renew}" != "0" ]; then
            mark_current_tab "${session_ttl_default}"
          fi
          return 0
        fi
        if [ "${exec_cmd[1]:-}" = "close" ]; then
          ensure_session_tab || return $?
          if load_session_lease 2>/dev/null; then
            run_agent_browser "${exec_cmd[@]}"
            lease_remove
            return 0
          fi
        fi
        ensure_session_tab || return $?
        ;;
      *)
        ensure_session_tab || return $?
        ;;
    esac

  fi

  if run_agent_browser "${exec_cmd[@]}"; then
    status=0
  else
    status=$?
  fi

  if [ "${status}" -eq 0 ] && [ -n "${session_name}" ] && [ "${session_auto_renew}" != "0" ] && ! { [ "${exec_cmd[0]}" = "tab" ] && [ "${exec_cmd[1]:-}" = "close" ]; }; then
    mark_current_tab "${session_ttl_default}"
  fi

  return "${status}"
}

exec_cmd=("$@")
if [ "${#exec_cmd[@]}" -eq 0 ]; then
  echo "Usage: agent-browser-cdp <agent-browser args...>" >&2
  exit 1
fi

with_command_lock main
