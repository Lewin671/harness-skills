#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cdp_url="$("${script_dir}/ensure-cdp-browser")"
host="${SHARED_CDP_BROWSER_HOST:-127.0.0.1}"
port="${SHARED_CDP_BROWSER_PORT:-9222}"
lock_key="${host//[^[:alnum:]]/_}-${port}"
session_name="${SHARED_CDP_BROWSER_SESSION:-}"
session_name_b64="$(printf '%s' "${session_name}" | base64 | tr -d '\r\n')"
session_key="$(printf '%s' "${session_name_b64}" | tr '/+=' '_-.')"
command_lock="${SHARED_CDP_BROWSER_COMMAND_LOCK:-/tmp/shared-cdp-browser-command-${lock_key}.lock}"
session_ttl_default="${SHARED_CDP_BROWSER_SESSION_TTL:-1800}"
session_auto_renew="${SHARED_CDP_BROWSER_AUTO_RENEW:-1}"
use_command_lock="${SHARED_CDP_BROWSER_USE_LOCK:-0}"
lock_stale_after="${SHARED_CDP_BROWSER_LOCK_STALE_AFTER:-5}"
state_dir="${SHARED_CDP_BROWSER_STATE_DIR:-${TMPDIR:-/tmp}/shared-cdp-browser-state-${lock_key}}"
lease_dir="${state_dir}/leases"

now_epoch() {
  date +%s
}

require_positive_integer() {
  local value="${1}"
  local label="${2}"

  if ! [[ "${value}" =~ ^[0-9]+$ ]] || [ "${value}" -le 0 ]; then
    echo "${label} must be a positive integer." >&2
    exit 1
  fi
}

process_start_time() {
  local pid="${1}"
  ps -o lstart= -p "${pid}" 2>/dev/null | sed 's/^[[:space:]]*//'
}

lock_age_seconds() {
  local path="${1}"
  local modified_at

  modified_at="$(date -r "${path}" +%s 2>/dev/null)" || return 1
  echo "$(( $(now_epoch) - modified_at ))"
}

require_session_name() {
  if [ -z "${session_name}" ]; then
    echo "SHARED_CDP_BROWSER_SESSION must be set for session commands." >&2
    exit 1
  fi
}

parse_ttl_flag() {
  local ttl="${session_ttl_default}"
  local arg

  while [ "${#session_args[@]}" -gt 0 ]; do
    arg="${session_args[0]}"
    case "${arg}" in
      --ttl)
        if [ "${#session_args[@]}" -lt 2 ]; then
          echo "--ttl requires a value." >&2
          exit 1
        fi
        ttl="${session_args[1]}"
        session_args=("${session_args[@]:2}")
        ;;
      --ttl=*)
        ttl="${arg#--ttl=}"
        session_args=("${session_args[@]:1}")
        ;;
      *)
        break
        ;;
    esac
  done

  require_positive_integer "${ttl}" "TTL"
  parsed_ttl="${ttl}"
}

run_agent_browser() {
  local cmd=()
  if command -v agent-browser >/dev/null 2>&1; then
    cmd=(agent-browser)
  else
    cmd=(npx -y agent-browser)
  fi

  cmd+=(--cdp "${cdp_url}")
  if [ -n "${session_name}" ]; then
    cmd+=(--session "${session_name}")
  fi

  "${cmd[@]}" "$@"
}

ensure_state_dirs() {
  mkdir -p "${lease_dir}"
}

lease_file_path() {
  printf '%s/%s.lease\n' "${lease_dir}" "${session_key}"
}

lease_remove() {
  local lease_file
  lease_file="$(lease_file_path)"
  rm -f "${lease_file}"
}

read_lease_file() {
  local lease_file="${1}"
  [ -f "${lease_file}" ] || return 1

  lease_session_name_b64=""
  lease_target_id=""
  lease_expires_at=""
  lease_ttl=""

  while IFS='=' read -r key value; do
    case "${key}" in
      session_name_b64) lease_session_name_b64="${value}" ;;
      target_id) lease_target_id="${value}" ;;
      expires_at) lease_expires_at="${value}" ;;
      ttl) lease_ttl="${value}" ;;
    esac
  done <"${lease_file}"

  [ -n "${lease_target_id}" ] || return 1
  [[ "${lease_expires_at}" =~ ^[0-9]+$ ]] || return 1
  [[ "${lease_ttl}" =~ ^[0-9]+$ ]] || return 1
}

load_session_lease() {
  local lease_file
  lease_file="$(lease_file_path)"
  read_lease_file "${lease_file}"
}

json_filter() {
  local script="${1}"

  if command -v python3 >/dev/null 2>&1; then
    python3 -c "${script}"
    return
  fi

  python -c "${script}"
}

list_targets_tsv() {
  local targets_json

  targets_json="$(curl --silent --show-error --fail "${cdp_url}/json/list")"
  printf '%s' "${targets_json}" | json_filter '
import json
import sys

data = json.load(sys.stdin)
for item in data:
    if item.get("type") != "page":
        continue
    target_id = item.get("id", "")
    if not target_id:
        continue
    title = item.get("title", "").replace("\t", " ").replace("\n", " ")
    url = item.get("url", "").replace("\t", " ").replace("\n", " ")
    print(f"{target_id}\t{title}\t{url}")
'
}

target_exists() {
  local target_id="${1}"
  list_targets_tsv | awk -F '\t' -v target_id="${target_id}" '$1 == target_id { found = 1 } END { exit(found ? 0 : 1) }'
}

close_target() {
  local target_id="${1}"

  if curl --silent --show-error --fail "${cdp_url}/json/close/${target_id}" >/dev/null 2>&1; then
    return 0
  fi

  local idx
  idx="$(list_targets_tsv | awk -F '\t' -v target_id="${target_id}" '$1 == target_id { print NR - 1; found = 1; exit } END { exit(found ? 0 : 1) }')" || return 1
  run_agent_browser tab close "${idx}" >/dev/null
}

capture_target_ids() {
  list_targets_tsv | awk -F '\t' '{ print $1 }'
}

find_new_target_id() {
  local before_file="${1}"
  local after_file="${2}"

  awk 'NR==FNR { seen[$0]=1; next } !seen[$0] { print; exit }' "${before_file}" "${after_file}"
}

lease_write() {
  local target_id="${1}"
  local expires_at="${2}"
  local ttl="${3}"
  local lease_file tmp_file

  ensure_state_dirs
  lease_file="$(lease_file_path)"
  tmp_file="$(mktemp "${lease_file}.tmp.XXXXXX")"
  cat >"${tmp_file}" <<EOF
session_name_b64=${session_name_b64}
target_id=${target_id}
expires_at=${expires_at}
ttl=${ttl}
EOF
  mv -f "${tmp_file}" "${lease_file}"
}

mark_target() {
  local target_id="${1}"
  local ttl="${2:-${session_ttl_default}}"
  local expires_at

  [ -n "${session_name}" ] || return 0
  [ -n "${target_id}" ] || return 1
  require_positive_integer "${ttl}" "TTL"
  expires_at="$(( $(now_epoch) + ttl ))"
  lease_write "${target_id}" "${expires_at}" "${ttl}"
}

mark_current_tab() {
  local ttl="${1:-${session_ttl_default}}"

  [ -n "${session_name}" ] || return 0
  if ! load_session_lease 2>/dev/null; then
    return 1
  fi
  if ! target_exists "${lease_target_id}"; then
    return 1
  fi
  mark_target "${lease_target_id}" "${ttl}"
}

cleanup_stale_session_tabs() {
  local now lease_file

  cleanup_removed_count=0
  ensure_state_dirs
  now="$(now_epoch)"

  while IFS= read -r lease_file; do
    [ -n "${lease_file}" ] || continue

    if ! read_lease_file "${lease_file}"; then
      continue
    fi

    if ! target_exists "${lease_target_id}"; then
      rm -f "${lease_file}"
      continue
    fi

    if [ "${lease_expires_at}" -gt "${now}" ]; then
      continue
    fi

    if close_target "${lease_target_id}" >/dev/null 2>&1 || ! target_exists "${lease_target_id}"; then
      rm -f "${lease_file}"
      cleanup_removed_count=$((cleanup_removed_count + 1))
    fi
  done < <(find "${lease_dir}" -type f -name '*.lease' -print 2>/dev/null | sort)
}

session_status() {
  local now remaining

  require_session_name
  cleanup_stale_session_tabs

  if ! load_session_lease 2>/dev/null; then
    echo "session=${session_name}"
    echo "status=missing"
    return 1
  fi

  if ! target_exists "${lease_target_id}"; then
    lease_remove
    echo "session=${session_name}"
    echo "status=missing"
    return 1
  fi

  now="$(now_epoch)"
  remaining="$(( lease_expires_at - now ))"
  if [ "${remaining}" -lt 0 ]; then
    remaining=0
  fi

  echo "session=${session_name}"
  echo "status=active"
  echo "target_id=${lease_target_id}"
  echo "ttl_seconds=${lease_ttl}"
  echo "expires_at=${lease_expires_at}"
  echo "remaining_seconds=${remaining}"
}

session_open() {
  local target_id

  require_session_name
  parse_ttl_flag
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session open does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs

  if load_session_lease 2>/dev/null && target_exists "${lease_target_id}"; then
    mark_target "${lease_target_id}" "${parsed_ttl}"
    session_status
    return 0
  fi

  lease_remove
  target_id="$(
    local before_ids after_ids identified_target

    before_ids="$(mktemp)"
    after_ids="$(mktemp)"
    trap 'rm -f "${before_ids}" "${after_ids}"' EXIT

    capture_target_ids >"${before_ids}"
    run_agent_browser tab new >/dev/null
    capture_target_ids >"${after_ids}"
    identified_target="$(find_new_target_id "${before_ids}" "${after_ids}" || true)"

    if [ -z "${identified_target}" ]; then
      identified_target="$(tail -n 1 "${after_ids}" | tr -d '\r\n' || true)"
    fi

    printf '%s\n' "${identified_target}"
  )"

  if [ -z "${target_id}" ]; then
    echo "Unable to identify the tab created for session ${session_name}." >&2
    exit 1
  fi

  mark_target "${target_id}" "${parsed_ttl}"
  session_status
}

session_renew() {
  require_session_name
  parse_ttl_flag
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session renew does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs

  if ! load_session_lease 2>/dev/null || ! target_exists "${lease_target_id}"; then
    lease_remove
    echo "Session not found: ${session_name}" >&2
    exit 1
  fi

  mark_target "${lease_target_id}" "${parsed_ttl}"
  session_status
}

session_close() {
  require_session_name
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session close does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs

  if ! load_session_lease 2>/dev/null || ! target_exists "${lease_target_id}"; then
    lease_remove
    echo "session=${session_name}"
    echo "status=missing"
    return 1
  fi

  close_target "${lease_target_id}" >/dev/null
  lease_remove
  echo "session=${session_name}"
  echo "status=closed"
}

session_cleanup() {
  if [ "${#session_args[@]}" -gt 0 ]; then
    echo "session cleanup does not accept extra arguments." >&2
    exit 1
  fi

  cleanup_stale_session_tabs
  echo "removed=${cleanup_removed_count}"
}

handle_session_command() {
  local subcommand="${exec_cmd[1]:-}"

  session_args=("${exec_cmd[@]:2}")
  case "${subcommand}" in
    open)
      session_open
      ;;
    renew)
      session_renew
      ;;
    ttl)
      if [ "${#session_args[@]}" -gt 0 ]; then
        echo "session ttl does not accept extra arguments." >&2
        exit 1
      fi
      session_status
      ;;
    close)
      session_close
      ;;
    cleanup)
      session_cleanup
      ;;
    ""|list)
      run_agent_browser "${exec_cmd[@]}"
      ;;
    *)
      echo "Unknown session command: ${subcommand}" >&2
      exit 1
      ;;
  esac
}

write_lock_owner() {
  {
    printf 'pid=%s\n' "$$"
    printf 'started=%s\n' "$(process_start_time "$$")"
  } >"${lock_pid_file}"
}

read_lock_owner() {
  lock_owner_pid=""
  lock_owner_started=""
  [ -f "${lock_pid_file}" ] || return 1

  while IFS='=' read -r key value; do
    case "${key}" in
      pid) lock_owner_pid="${value}" ;;
      started) lock_owner_started="${value}" ;;
    esac
  done <"${lock_pid_file}"

  [ -n "${lock_owner_pid}" ] || return 1
}

lock_is_stale() {
  local current_start lock_age

  if ! read_lock_owner; then
    lock_age="$(lock_age_seconds "${lock_dir}" 2>/dev/null || true)"
    [ -n "${lock_age}" ] && [ "${lock_age}" -ge "${lock_stale_after}" ]
    return
  fi

  if ! kill -0 "${lock_owner_pid}" 2>/dev/null; then
    return 0
  fi

  current_start="$(process_start_time "${lock_owner_pid}")"
  [ -n "${current_start}" ] || return 0
  [ "${current_start}" != "${lock_owner_started}" ]
}

with_optional_command_lock() {
  if [ "${use_command_lock}" != "1" ]; then
    "$@"
    return
  fi

  if [ "${SHARED_CDP_BROWSER_DISABLE_FLOCK:-0}" != "1" ] && command -v flock >/dev/null 2>&1; then
    exec 9>"${command_lock}"
    flock 9
    "$@"
    return
  fi

  local lock_dir="${command_lock}.d"
  lock_pid_file="${lock_dir}/pid"
  local status

  while ! mkdir "${lock_dir}" 2>/dev/null; do
    if lock_is_stale; then
      rm -f "${lock_pid_file}"
      rmdir "${lock_dir}" 2>/dev/null || true
      continue
    fi
    sleep 0.1
  done

  write_lock_owner
  if "$@"; then
    status=0
  else
    status=$?
  fi
  rm -f "${lock_pid_file}"
  rmdir "${lock_dir}" 2>/dev/null || true
  return "${status}"
}

main() {
  local status current_exists

  if [ "${exec_cmd[0]}" = "session" ] && [ "${#exec_cmd[@]}" -ge 2 ]; then
    handle_session_command
    return 0
  fi

  cleanup_stale_session_tabs

  if run_agent_browser "${exec_cmd[@]}"; then
    status=0
  else
    status=$?
  fi

  if [ "${status}" -ne 0 ] || [ -z "${session_name}" ] || [ "${session_auto_renew}" = "0" ]; then
    return "${status}"
  fi

  if [ "${exec_cmd[0]}" = "tab" ] && [ "${exec_cmd[1]:-}" = "close" ]; then
    if load_session_lease 2>/dev/null; then
      current_exists=0
      if target_exists "${lease_target_id}"; then
        current_exists=1
      fi

      if [ "${current_exists}" -eq 0 ]; then
        lease_remove
        return 0
      fi
    fi
  fi

  if ! mark_current_tab "${session_ttl_default}"; then
    lease_remove
  fi

  return 0
}

exec_cmd=("$@")
if [ "${#exec_cmd[@]}" -eq 0 ]; then
  echo "Usage: agent-browser-cdp <agent-browser args...>" >&2
  exit 1
fi

with_optional_command_lock main
